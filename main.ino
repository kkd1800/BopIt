void setup() {
  display.begin();
  delay(1000);
  display.clear();
  display.draw_bitmap_P(0, 0, 128, 64, targetingDisplay);
  display.display();

  display.draw_bitmap_P(0, 0, 128, 64,welcomeScreen);
  display.display();
  
  uint8_t loadingBar[56];
  memcpy_P(loadingBar, loadingBar_template, 56);  // copy flash → RAM

  for (uint8_t row = 1; row <= 57; row++){
    
    if(row <= 54) loadingBar[row] = 25;

    if(row >= 2) loadingBar[row-1] = 29;

    if(row >= 3) loadingBar[row-2] = 31;

    display.draw_bitmap(65, 32, 56, 5,loadingBar);
    display.display();
  }
}

